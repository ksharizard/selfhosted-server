{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "prBodyTemplate": "{{{header}}}{{{table}}}{{{warnings}}}{{{notes}}}{{{changelogs}}}",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "automerge": false
    },
    {
      "description": "Disable updates for immich postgres",
      "matchPackageNames": ["ghcr.io/immich-app/postgres"],
      "enabled": false
    },
    {
      // linuxserver pushed a 20.04.1 image tag that they refuse to remove
      "description": "Skip bad image versions for qbittorrent",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "allowedVersions": "<10.0.0"
    },
    {
      "description": "Fetch upstream changelogs for beets",
      "matchDatasources": ["docker"],
      "matchDepNames": ["lscr.io/linuxserver/beets"],
      "sourceUrl": "https://github.com/beetbox/beets",
      "changelogUrl": "https://github.com/beetbox/beets"
    },
    {
      "description": "Fetch upstream changelogs for jellyfin",
      "matchDatasources": ["docker"],
      "matchDepNames": ["lscr.io/linuxserver/jellyfin"],
      "sourceUrl": "https://github.com/jellyfin/jellyfin",
      "changelogUrl": "https://github.com/jellyfin/jellyfin"
    },
    {
      "description": "Fetch upstream changelogs for prowlarr",
      "matchDatasources": ["docker"],
      "matchDepNames": ["lscr.io/linuxserver/prowlarr"],
      "sourceUrl": "https://github.com/Prowlarr/Prowlarr",
      "changelogUrl": "https://github.com/Prowlarr/Prowlarr"
    },
    {
      "description": "Fetch upstream changelogs for qbittorrent",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "sourceUrl": "https://github.com/qbittorrent/qBittorrent",
      "changelogUrl": "https://github.com/qbittorrent/qBittorrent"
    },
    {
      "description": "Fetch upstream changelogs for radarr",
      "matchDatasources": ["docker"],
      "matchDepNames": ["lscr.io/linuxserver/radarr"],
      "sourceUrl": "https://github.com/Radarr/Radarr",
      "changelogUrl": "https://github.com/Radarr/Radarr"
    },
    {
      "description": "Fetch upstream changelogs for sonarr",
      "matchDatasources": ["docker"],
      "matchDepNames": ["lscr.io/linuxserver/sonarr"],
      "sourceUrl": "https://github.com/Sonarr/Sonarr",
      "changelogUrl": "https://github.com/Sonarr/Sonarr"
    }
  ]
}
