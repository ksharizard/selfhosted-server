{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "prBodyTemplate": "{{{header}}}{{{table}}}{{{warnings}}}{{{notes}}}{{{changelogs}}}",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "automerge": false
    },
    {
      "description": "Disable updates for immich postgres",
      "matchPackageNames": ["ghcr.io/immich-app/postgres"],
      "enabled": false
    },
    {
      // linuxserver pushed a 20.04.1 image tag that they refuse to remove
      "description": "Skip bad image versions for qbittorrent",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "allowedVersions": "<10.0.0"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/qbittorrent"],
      "changelogUrl": "https://github.com/qbittorrent/qBittorrent/releases/tag/release-{{newVersion}}"
    },

    /* Linuxserver.io images prefixed with 'version' */
    {
      "matchDatasources": ["docker"],
      "matchPackagePatterns": ["^lscr\\.io\\/linuxserver\\/"],
      "versioning": "regex:^version-v?(?<major>\\d+)\\.(?<minor>\\d+)(\\.(?<patch>\\d+))?(\\.(?<build>.*))?$"
    }
  ]
}
